{
  "expo": {
    "name": "SportMap",
    "slug": "sportmap-mobile",
    "version": "1.0.0",
    "scheme": "sportmap",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SportMap a besoin de votre position pour afficher les infrastructures autour de vous.",
          "locationAlwaysAndWhenInUsePermission": "SportMap utilise votre position pour vous situer sur la carte sportive."
        }
      ],
      "expo-router",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox",
          "RNMapboxMapsDownloadToken": "sk.XXXXXXX",
          "RNMapboxMapsVersion": "10.17.0"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "bundleIdentifier": "com.anonymous.sportmap-mobile"
    }
  }
}
